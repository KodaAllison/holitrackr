# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Secret used to sign sessions and cookies — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# Base URL for your app (server-side)
BETTER_AUTH_URL=http://localhost:5173

# Base URL exposed to the Vite client bundle
VITE_BETTER_AUTH_URL=http://localhost:5173

# Optional: path to SQLite database file (defaults to ./auth.db, dev only)
# AUTH_DB_PATH=./auth.db
